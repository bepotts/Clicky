# Conservative SwiftFormat config for a typical iOS / SwiftUI project
# SwiftFormat owns mechanical formatting; SwiftLint owns code-quality checks.

--indent 4
--linebreaks lf
--maxwidth 120
--trimwhitespace always
--semicolons inline
--commas inline
--ranges nospace
--wraparguments before-first
--wrapparameters before-first
--wrapcollections before-first
--closingparen balanced
--callsiteparen balanced
--stripunusedargs closure-only
--self remove
--patternlet hoist
--ifdef no-indent
--xcodeindentation enabled
--header ignore
--swiftversion 5.10
--exclude Pods,Carthage,build,.build,DerivedData
